{
  "name": "narratox",
  "version": "0.0.0",
  "private": true,
  "description": "Orchestration root — runs the frontend and server sub-projects in parallel.",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:server": "PORT=3001 pnpm --dir server start:dev",
    "dev:agent-ui": "pnpm --dir agent-ui dev",
    "build": "run-p build:*",
    "build:server": "pnpm --dir server build",
    "build:agent-ui": "pnpm --dir agent-ui build"
  },
  "devDependencies": {
    "npm-run-all2": "^8.0.4"
  }
}
