                  "type": "text",
                  "id": "r2QZg",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "建立主角的日常世界、核心欲望与致命缺陷。结尾的「激励事件」打破现状,迫使主角踏上旅程。这一幕承担「读者为什么要在意这个主角」的责任。",
                  "lineHeight": 1.7,
                  "fontFamily": "$font-sans",
                  "fontSize": "$text-sm",
                  "fontWeight": "normal"
                },
