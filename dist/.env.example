# === docker compose 全家桶自托管(NAS)===
# 用法:
#   docker load -i narratox-<arch>.tar.gz
#   cp .env.example .env  →  填 JWT_SECRET + IMAGE_TAG + 端口
#   docker compose up -d  (不加 --build,镜像已从 tar load)
# 详见 NAS-DEPLOY.md。

# 镜像架构标签(必看)—— 必须跟 load 的 tar 对齐:
#   load narratox-amd64.tar.gz → IMAGE_TAG=amd64
#   load narratox-arm64.tar.gz → IMAGE_TAG=arm64
# NAS SSH 跑 `uname -m`:x86_64=amd64,aarch64/arm64=arm64。
IMAGE_TAG=amd64

# Caddy 站点地址:
# - 默认 :80(Caddy 任意 host + 纯 HTTP)—— 适配 NAS 局域网 IP 访问(http://nas-ip:<宿主端口>)。
# - prod:裸域名,如 narratox.example.com(无 http:// 前缀 → Caddy 自动签 Let's Encrypt 并启 HTTPS)。
CADDY_DOMAIN=:80

# Caddy 宿主端口(NAS 上 80/443 常被系统占,默认用非特权端口)。
# 容器内始终 80/443,这里只控制「宿主 → 容器」映射。
# NAS 局域网访问用 HTTP 端口(如 http://nas-ip:8080);设了 prod 域名才需要 HTTPS 端口。
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

# agent-ui 构建期默认 endpoint(可选 —— 默认不设,浏览器用自身 origin,零配置同源走 Caddy)。
# 仅当 agent-ui 与 server 不同源(跨源部署)才显式设为 server 的完整 URL。
# 不设 → store 回退 window.location.origin:打开 http://localhost 默认连 localhost,
#        打开 https://<域名> 默认连该域名。
# NEXT_PUBLIC_DEFAULT_ENDPOINT=

# JWT 签名密钥(必填)—— 缺失 compose 会拒绝启动。
# 生成强随机:openssl rand -hex 32
JWT_SECRET=

# Postgres 凭证(默认弱密码仅本地;prod 必改)。
POSTGRES_USER=narratox
POSTGRES_PASSWORD=narratox
POSTGRES_DB=narratox
