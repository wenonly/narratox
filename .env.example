# === docker compose 全家桶自托管 ===
# 用法:cp .env.example .env,改完 `docker compose up -d --build`。
# 详见 docs/deployment.md。

# Caddy 站点地址:
# - 本地:http://localhost(带 http:// 前缀 → 纯 HTTP :80,不签证书、不跳转)
# - prod:裸域名,如 narratox.example.com(无前缀 → Caddy 自动签 Let's Encrypt 并启 HTTPS :443,
#   :80 自动重定向到 :443)
CADDY_DOMAIN=http://localhost

# agent-ui 构建期默认 endpoint(可选 —— 默认不设,浏览器用自身 origin,零配置同源走 Caddy)。
# 仅当 agent-ui 与 server 不同源(跨源部署)才显式设为 server 的完整 URL。
# 不设 → store 回退 window.location.origin:打开 http://localhost 默认连 localhost,
#        打开 https://<域名> 默认连该域名。
# NEXT_PUBLIC_DEFAULT_ENDPOINT=

# JWT 签名密钥(必填)—— 缺失 compose 会拒绝启动。
# 生成强随机:openssl rand -hex 32
JWT_SECRET=

# Postgres 凭证(默认弱密码仅本地;prod 必改)。
POSTGRES_USER=narratox
POSTGRES_PASSWORD=narratox
POSTGRES_DB=narratox
