# 模型 Provider 的 API Key 不再放 .env —— 在设置页(/settings)按用户配置并激活。

# 服务端口（dev:server 已固定 3001，可不设）
PORT=3001

# Postgres (Prisma) — local dev defaults matching docker-compose.yml
DATABASE_URL=postgresql://narratox:narratox@localhost:5432/narratox?schema=public

# JWT (auth)
JWT_SECRET=

# KB_DIR=/abs/path/to/知识库   # 可选：覆盖全局知识库目录（默认 <repo>/知识库）
