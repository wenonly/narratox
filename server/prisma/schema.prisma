generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  username     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  sessions     Session[]
  novels            Novel[]
  modelConfigs      ModelConfig[]
  novelReferences   NovelReference[]
  activeModelConfigId String? @unique
  activeModelConfig   ModelConfig? @relation("ActiveModel", fields: [activeModelConfigId], references: [id], onDelete: SetNull)
  voiceProfiles       VoiceProfile[]
}

model Session {
  // Externally supplied identity: this id equals the UI session_id and the
  // LangGraph thread_id. Intentionally has NO default so a missing id fails
  // loudly rather than silently auto-generating a mismatched id.
  id        String    @id
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   String    @default("deep-agent")
  name      String
  createdAt DateTime  @default(now())
  // Bumped explicitly by SessionsService.appendTurn. Intentionally NOT
  // @updatedAt so it remains explicitly settable and testable.
  updatedAt DateTime  @default(now())
  messages  Message[]
  novel     Novel?

  @@index([agentId])
  @@index([userId, updatedAt])
}

model Message {
  id          String   @id @default(cuid())
  sessionId   String
  role        String
  content     String
  activities  Json?
  isError     Boolean  @default(false)
  langGraphId String?
  createdAt   DateTime @default(now())
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Novel {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String       @unique
  session   Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title     String
  genre     String?
  synopsis  String?
  settings  Json         @default("{}")
  status    NovelStatus  @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @default(now())
  chapters        Chapter[]
  events          StoryEvent[]
  volumes         Volume[]
  chapterOutlines ChapterOutline[]
  worldEntries    WorldEntry[]
  characters      Character[]
  references      NovelReference[]
  voiceProfileId  String?
  voiceProfile    VoiceProfile? @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
}

model Chapter {
  id        String          @id @default(cuid())
  novelId   String
  novel     Novel           @relation(fields: [novelId], references: [id], onDelete: Cascade)
  order     Int
  title     String
  content   String          @default("")
  status    ChapterStatus   @default(DRAFT)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now())
  summary   ChapterSummary?

  @@unique([novelId, order])
}

enum ChapterStatus {
  DRAFT
  COMMITTED
}

enum NovelStatus {
  CONCEPT
  ACTIVE
}

model ChapterSummary {
  id          String   @id @default(cuid())
  chapterId   String   @unique
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  novelId     String
  summary     String   @default("")
  roleChanges Json     @default("[]")
  entities    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([novelId])
}

model StoryEvent {
  id                   String           @id @default(cuid())
  novelId              String
  novel                Novel            @relation(fields: [novelId], references: [id], onDelete: Cascade)
  description          String
  status               EventStatus      @default(OPEN)
  payoffTiming         HookPayoffTiming @default(MID_ARC)
  openedAtChapter      Int?
  resolvedAtChapter    Int?
  advancedCount        Int              @default(0)
  coreHook             Boolean          @default(false)
  lastAdvancedAtChapter Int?
  dependsOn            String[]         @default([])
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @default(now())

  @@index([novelId, status])
}

enum EventStatus {
  OPEN
  PROGRESSING
  RESOLVED
}

enum HookPayoffTiming {
  IMMEDIATE
  NEAR_TERM
  MID_ARC
  SLOW_BURN
  ENDGAME
}

// ── 大纲(Phase C1)─────────────────────────────────────────────
// 两层结构化大纲:Volume(大纲/卷纲,全书骨架)+ ChapterOutline(细纲,每章计划)。
// ChapterOutline 按 (novelId, chapterOrder) 唯一——先于 Chapter 行存在(计划先于写作),
// 不与 Chapter 做 FK。节点统一 { subject, action, target }(主体|动作|对象)。

model Volume {
  id             String           @id @default(cuid())
  novelId        String
  novel          Novel            @relation(fields: [novelId], references: [id], onDelete: Cascade)
  order          Int
  title          String
  goal           String           @default("")
  synopsis       String           @default("")
  chapterOutlines ChapterOutline[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([novelId, order])
  @@index([novelId])
}

model ChapterOutline {
  id           String              @id @default(cuid())
  novelId      String
  novel        Novel               @relation(fields: [novelId], references: [id], onDelete: Cascade)
  volumeId     String?
  volume       Volume?             @relation(fields: [volumeId], references: [id], onDelete: SetNull)
  chapterOrder Int
  title        String              @default("")
  cbn          Json                // 开篇节点 { subject, action, target }
  cpns         Json                // 情节节点 [{ subject, action, target }, ...] (2-4)
  cen          Json                // 结尾节点 { subject, action, target }
  mustCover    Json                // string[]  必须覆盖(≤4)
  forbidden    Json                // string[]  本章禁区(≤5)
  status       ChapterOutlineStatus @default(DRAFT)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([novelId, chapterOrder])
  @@index([novelId])
}

enum ChapterOutlineStatus {
  DRAFT
  APPROVED
  WRITTEN
}

// ── 世界观(Phase 2 资源)─────────────────────────────────────────
// 类型化条目(codex/lorebook):世界观 = 一组带类型的设定卡片。
// 按 (novelId, name) 唯一(一个地点/势力在书内只一条)。content 自由 markdown。
// concept vs rule 保留 inkos 的「设定 vs 规则禁忌」二分。

model WorldEntry {
  id        String         @id @default(cuid())
  novelId   String
  novel     Novel          @relation(fields: [novelId], references: [id], onDelete: Cascade)
  type      WorldEntryType
  name      String
  content   String         @default("")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([novelId, name])
  @@index([novelId, type])
}

enum WorldEntryType {
  concept      // 设定/背景/总览
  powerSystem  // 力量体系(魔法/科技/修炼)
  location     // 地点
  faction      // 势力/组织/门派/国家
  race         // 种族/生物
  rule         // 规则/禁忌(力量上限、不可做)
  item         // 物品/资源/经济
  history      // 历史传说/纪年
}

// ── 小说级参考资料(Plan 2)─────────────────────────────────────────
// curator 子 agent 在立项时从全局 KB 提炼出本书专属参考资料(去冗余),
// 固化进 DB;写大纲/写正文时按 injectTo 注入对应 agent context,其余条目
// 由 agent 用 get_reference 工具按需拉取。属 novel 数据,与世界观/大纲一致。

model NovelReference {
  id        String   @id @default(cuid())
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  String   @default("")
  content   String   @default("")
  injectTo  String?  // 'main' | 'writer' | 'both' | null(null=仅工具可取)
  source    String?  // provenance:来源全局 KB 条目 id 列表(JSON 串),便于追溯
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([novelId])
}

// ── 角色(B2 资源):事件驱动时间线 ──────────────────────────────
// Character = 稳定身份(name/aliases/role/faction/background)。
// CharacterChange = 演变时间线(每维度变化:第几章/field/value/reason)。
// 当前态 = 每维度最新 CharacterChange 的 value(派生,不直接 CRUD)。

model Character {
  id         String         @id @default(cuid())
  novelId    String
  novel      Novel          @relation(fields: [novelId], references: [id], onDelete: Cascade)
  name       String
  aliases    String[]       @default([])
  role       CharacterRole  @default(SUPPORTING)
  faction    String         @default("")
  background String         @default("")
  appearance String         @default("")
  personality String        @default("")
  motivation String         @default("")
  arcGoal    String         @default("")
  voice      String         @default("")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  changes    CharacterChange[]

  @@unique([novelId, name])
  @@index([novelId])
}

model CharacterChange {
  id           String    @id @default(cuid())
  novelId      String
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  chapterOrder Int
  field        String
  value        String
  reason       String    @default("")
  createdAt    DateTime   @default(now())

  @@index([characterId, chapterOrder])
  @@index([novelId])
}

enum CharacterRole {
  PROTAGONIST
  ANTAGONIST
  SUPPORTING
}

model ModelConfig {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  provider    String
  model       String
  baseUrl     String?
  apiKey      String
  temperature Float?
  activeForUser User?   @relation("ActiveModel")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ── 作者画像(P1.6)─────────────────────────────────────────────
// 每用户的画像库(替代旧的单全局 User.voiceProfile String)。
// Novel.voiceProfileId 指向一本小说当前选用的画像(SetNull:删画像不删小说)。
// P1.5 旧 User.voiceProfile 非空值已迁移为名为「默认画像」的 VoiceProfile 行。

model VoiceProfile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  profile   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  novels    Novel[]

  @@index([userId])
}
